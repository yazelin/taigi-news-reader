# The default is the real Ollama -> Meta MMS pipeline. `mock` is only for tests
# and local UI development; it never silently activates on provider failures.
TAIGI_PROVIDER_MODE=concrete
TAIGI_TRANSLATOR_PROVIDER=ollama
TAIGI_TTS_PROVIDER=mms

TAIGI_OLLAMA_BASE_URL=http://127.0.0.1:11434
TAIGI_OLLAMA_MODEL=qwen3:4b-instruct-2507-q4_K_M
TAIGI_OLLAMA_TIMEOUT_SECONDS=45

TAIGI_MMS_MODEL=facebook/mms-tts-nan
TAIGI_MMS_DEVICE=cpu
TAIGI_MMS_TIMEOUT_SECONDS=180

# Hosted adapters (used when the provider selections above are changed).
# The translation endpoint must implement POST /chat/completions.
TAIGI_OPENAI_BASE_URL=
TAIGI_OPENAI_API_KEY=
TAIGI_OPENAI_MODEL=
TAIGI_OPENAI_TIMEOUT_SECONDS=45

# Groq example (ordinary users never see this server-side key):
# TAIGI_TRANSLATOR_PROVIDER=openai_compatible
# TAIGI_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# TAIGI_OPENAI_API_KEY=replace-with-groq-key
# TAIGI_OPENAI_MODEL=openai/gpt-oss-120b

# Remote TTS accepts {text,language:"nan-TW",rate} and returns
# {audio_base64,mime_type:"audio/wav"}. The API key may be empty for a private
# trusted network; HTTPS is expected for internet deployments.
TAIGI_REMOTE_TTS_URL=
TAIGI_REMOTE_TTS_API_KEY=
TAIGI_REMOTE_TTS_TIMEOUT_SECONDS=180
TAIGI_MAX_AUDIO_BYTES=26214400

TAIGI_MAX_TEXT_CHARS=5000
TAIGI_MAX_TRANSLATED_CHARS=12000

# Comma-separated Chrome extension IDs. Empty means any syntactically valid
# Chrome extension origin, which is convenient while loading the extension
# unpacked. Pin this after the extension ID is stable.
TAIGI_EXTENSION_IDS=
TAIGI_ALLOW_LOCALHOST_ORIGINS=true
