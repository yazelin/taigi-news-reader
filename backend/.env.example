# The default is the real Ollama -> Meta MMS pipeline. `mock` is only for tests
# and local UI development; it never silently activates on provider failures.
TAIGI_PROVIDER_MODE=concrete
TAIGI_TRANSLATOR_PROVIDER=ollama
TAIGI_TTS_PROVIDER=mms

TAIGI_OLLAMA_BASE_URL=http://127.0.0.1:11434
TAIGI_OLLAMA_MODEL=qwen3:4b-instruct-2507-q4_K_M
TAIGI_OLLAMA_TIMEOUT_SECONDS=45

TAIGI_MMS_MODEL=facebook/mms-tts-nan
TAIGI_MMS_DEVICE=cpu
TAIGI_MMS_TIMEOUT_SECONDS=180

# Hosted adapters (used when the provider selections above are changed).
# The translation endpoint must implement POST /chat/completions.
TAIGI_OPENAI_BASE_URL=
TAIGI_OPENAI_API_KEY=
TAIGI_OPENAI_MODEL=
TAIGI_OPENAI_TIMEOUT_SECONDS=45

# Groq example (ordinary users never see this server-side key):
# TAIGI_TRANSLATOR_PROVIDER=openai_compatible
# TAIGI_OPENAI_BASE_URL=https://api.groq.com/openai/v1
# TAIGI_OPENAI_API_KEY=replace-with-groq-key
# TAIGI_OPENAI_MODEL=openai/gpt-oss-120b

# First-class Gemini translator via Google's OpenAI-compatible API. Only the
# server receives this key; never put it in the Chrome extension.
TAIGI_GEMINI_API_KEY=
TAIGI_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
TAIGI_GEMINI_MODEL=gemini-3.5-flash
TAIGI_GEMINI_TIMEOUT_SECONDS=45
# TAIGI_TRANSLATOR_PROVIDER=gemini

# Remote TTS accepts {text,language:"nan-TW",rate} and returns
# {audio_base64,mime_type:"audio/wav"}. The API key may be empty for a private
# trusted network; HTTPS is expected for internet deployments.
TAIGI_REMOTE_TTS_URL=
TAIGI_REMOTE_TTS_API_KEY=
TAIGI_REMOTE_TTS_TIMEOUT_SECONDS=180
TAIGI_MAX_AUDIO_BYTES=26214400

TAIGI_MAX_TEXT_CHARS=5000
TAIGI_MAX_TRANSLATED_CHARS=12000

# Comma-separated Chrome extension IDs. Empty means any syntactically valid
# Chrome extension origin, which is convenient while loading the extension
# unpacked. Pin this after the extension ID is stable.
TAIGI_EXTENSION_IDS=
TAIGI_ALLOW_LOCALHOST_ORIGINS=true

# A hosted/LAN deployment should set this to true. In strict mode every actual
# /v1/ request must carry X-Taigi-Extension-Id with a pinned ID. A supplied
# Origin must match that ID; CORS preflight instead requires the pinned Origin.
# Startup fails when TAIGI_EXTENSION_IDS is empty. /health remains available.
TAIGI_REQUIRE_ALLOWED_ORIGIN=false

# Optional private-tester access control. Local/mock development stays open by
# default. Configure only lowercase SHA-256 hashes—not plaintext invite tokens.
TAIGI_REQUIRE_ACCESS_TOKEN=false
TAIGI_ACCESS_TOKEN_HASHES=
TAIGI_QUOTA_DATABASE_PATH=./taigi-access.sqlite3
TAIGI_DAILY_SUBJECT_JOB_LIMIT=20
TAIGI_DAILY_SUBJECT_CHARACTER_LIMIT=50000
TAIGI_DAILY_GLOBAL_JOB_LIMIT=100
TAIGI_DAILY_GLOBAL_CHARACTER_LIMIT=250000

# Process-local job and retained-result bounds. Keep one worker/replica unless
# the in-memory job registry is replaced by shared durable infrastructure.
TAIGI_MAX_ACTIVE_JOBS=4
TAIGI_MAX_OUTSTANDING_JOBS=12
TAIGI_MAX_OUTSTANDING_JOBS_PER_SUBJECT=3
TAIGI_MAX_TERMINAL_RESULT_BYTES=134217728
TAIGI_MAX_TERMINAL_RESULT_BYTES_PER_SUBJECT=41943040
TAIGI_TERMINAL_JOB_TTL_SECONDS=600
