# Fail-closed LAN example: copy to backend.env, keep mode 0600, and fill the
# three blank values on the target host. Never commit backend.env.
TAIGI_PROVIDER_MODE=concrete
TAIGI_TRANSLATOR_PROVIDER=openai_compatible
TAIGI_TTS_PROVIDER=mms

TAIGI_OPENAI_API_KEY=
TAIGI_OPENAI_BASE_URL=https://api.groq.com/openai/v1
TAIGI_OPENAI_MODEL=openai/gpt-oss-120b
TAIGI_OPENAI_TIMEOUT_SECONDS=45

TAIGI_MMS_MODEL=facebook/mms-tts-nan
TAIGI_MMS_DEVICE=cpu
TAIGI_MMS_TIMEOUT_SECONDS=180

TAIGI_MAX_TEXT_CHARS=5000
TAIGI_MAX_TRANSLATED_CHARS=12000
TAIGI_MAX_AUDIO_BYTES=26214400

# Read the stable ID from chrome://extensions. Multiple IDs are comma-separated.
# Strict mode refuses to start while this is blank.
TAIGI_EXTENSION_IDS=
TAIGI_ALLOW_LOCALHOST_ORIGINS=false
TAIGI_REQUIRE_ALLOWED_ORIGIN=true

# Private-test access control. Generate a high-entropy invite token, give the
# plaintext only to that tester, and store only its SHA-256 below. Entries are
# comma-separated stable pseudonyms in subject=lowercase_sha256 form. Startup
# fails closed while strict mode is true and this list is blank.
TAIGI_REQUIRE_ACCESS_TOKEN=true
TAIGI_ACCESS_TOKEN_HASHES=
TAIGI_QUOTA_DATABASE_PATH=/var/lib/taigi/quota.sqlite3

# Atomic UTC-day quotas. Accepted synthesis requests consume one job plus the
# stripped Unicode character count even if they later fail or are cancelled.
TAIGI_DAILY_SUBJECT_JOB_LIMIT=20
TAIGI_DAILY_SUBJECT_CHARACTER_LIMIT=50000
TAIGI_DAILY_GLOBAL_JOB_LIMIT=100
TAIGI_DAILY_GLOBAL_CHARACTER_LIMIT=250000

# Bound process-local work and completed WAV retention. Terminal HTTP results
# are delivered once; the extension's follow-up DELETE removes the tombstone.
TAIGI_MAX_ACTIVE_JOBS=4
TAIGI_MAX_OUTSTANDING_JOBS=12
TAIGI_MAX_OUTSTANDING_JOBS_PER_SUBJECT=3
TAIGI_MAX_TERMINAL_RESULT_BYTES=134217728
TAIGI_MAX_TERMINAL_RESULT_BYTES_PER_SUBJECT=41943040
TAIGI_TERMINAL_JOB_TTL_SECONDS=600
